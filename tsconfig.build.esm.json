{
    "extends": "./tsconfig.json",
    "compilerOptions": {
      "noEmit": false,
      "rootDir": "src",
      "outDir": "dist/esm",
  
      "declaration": true,
      "declarationMap": true,
      "emitDeclarationOnly": false,
  
      "module": "ESNext",
      "target": "ES2020",
      "moduleResolution": "Bundler",
      "verbatimModuleSyntax": true
    },
    "include": ["src/**/*"]
  }
  